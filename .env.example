# --- Server ---
PORT=3000
DATABASE_PATH=./data/eccos.db

# --- Meta WhatsApp Cloud API (single tenant in v1) ---
META_GRAPH_VERSION=v24.0
# Permanent System User token with whatsapp_business_messaging + whatsapp_business_management
META_ACCESS_TOKEN=
# phone_number_id of the WABA phone number (from WhatsApp > API Setup)
META_PHONE_NUMBER_ID=
# WhatsApp Business Account id
META_WABA_ID=
# App Secret (App Dashboard > Settings > Basic) — verifies X-Hub-Signature-256
META_APP_SECRET=
# A string you choose; Meta echoes it back on the GET webhook challenge
META_WEBHOOK_VERIFY_TOKEN=change-me-to-a-random-string

# --- Eccos API auth ---
# Bearer key your apps use to call POST /v1/messages and GET /v1/templates
ECCOS_API_KEY=change-me-to-a-random-key

# --- Forwarding (where Eccos pushes normalized inbound + status events) ---
# e.g. https://your-app.example.com/whatsapp-events
SUBSCRIBER_WEBHOOK_URL=
# Shared secret; Eccos signs the forwarded body as X-Eccos-Signature: sha256=<hex>
SUBSCRIBER_SECRET=
# Max delivery attempts before a forwarded event is marked failed
FORWARD_MAX_ATTEMPTS=6
# Days to retain delivered/failed deliveries, inbound events, and outbound messages
# before pruning (applies to both the Bun and Workers targets)
RETENTION_DAYS=30

# --- Cloudflare Workers target only (Embedded Signup /connect) ---
# On the Workers target, set secrets with `wrangler secret put <NAME>` rather than this file.
# These two are only needed for the /connect (Embedded Signup) flow:
# META_APP_ID=
# META_ES_CONFIG_ID=
